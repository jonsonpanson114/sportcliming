generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model Video {
  id              String   @id @default(cuid())
  youtubeId       String   @unique
  title           String
  description     String?
  thumbnailUrl    String?
  publishedAt     DateTime
  transcript      String?
  summary         String?
  summaryData     String?
  difficultyLevel String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Favorite {
  id        String   @id @default(cuid())
  videoId   String   @unique
  createdAt DateTime @default(now())
}

model History {
  id        String   @id @default(cuid())
  videoId   String   @unique
  watchedAt DateTime @default(now())
}

model Tip {
  id         String   @id @default(cuid())
  title      String
  content    String
  category   String
  difficulty String?
  videoIds   String
  createdAt  DateTime @default(now())
}

model PracticeMenu {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
}

model Quiz {
  id        String   @id @default(cuid())
  videoId   String
  question  String
  options   String
  answer    String
  createdAt DateTime @default(now())
}

model VideoNote {
  id        String   @id @default(cuid())
  videoId   String   @unique
  note      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PracticeRecord {
  id             String   @id @default(cuid())
  gymName        String?
  date           DateTime @default(now())
  duration       Int?
  practiceMenuId String?
  videoId        String?
  routes         String
  reflection     String?
  nextGoal       String?
  createdAt      DateTime @default(now())
}

model QASession {
  id        String   @id @default(cuid())
  question  String
  answer    String
  sources   String?
  createdAt DateTime @default(now())
}
